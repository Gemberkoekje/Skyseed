{
  "_comment": "First-party Quark compat (QUARKISLANDPLAN #71, Phase 2) — Quark blossom trees + harvestable saplings as an OPTIONAL accent variant on the Forest seed's matching biome bands (Quark's own biome map: blue=snowy, lavender=swamp, orange=savanna, yellow=plains, red=badlands). Each band keeps its normal tree AND gains a blossom-grove variant (equal weight) that mixes in the blossom tree + drops its sapling. The selectors are byte-identical to the base forest bands so they MERGE (append a variant) instead of shadowing. Extras only, no seed. Inert without Quark (unknown tree features + sapling blocks are skipped).",
  "target": "skyseed:forest",
  "biome_overrides": [
    { "biomes": ["minecraft:snowy_plains", "minecraft:snowy_taiga", "minecraft:ice_spikes", "minecraft:snowy_slopes", "minecraft:frozen_peaks", "minecraft:jagged_peaks", "minecraft:snowy_beach"],
      "variants": [ { "weight": 1, "name": "blue_blossom", "decoration": {
        "trees": [ { "feature": "minecraft:spruce", "tries": 2, "spacing": 2 }, { "feature": "quark:blue_blossom", "tries": 3, "spacing": 3 } ],
        "ground": [ { "block": "minecraft:short_grass", "chance": 0.12 }, { "block": "quark:blue_blossom_sapling", "chance": 0.05 } ] } } ] },
    { "biomes": ["minecraft:swamp"],
      "variants": [ { "weight": 1, "name": "lavender_blossom", "decoration": {
        "trees": [ { "feature": "minecraft:swamp_oak", "tries": 3, "spacing": 2 }, { "feature": "quark:lavender_blossom", "tries": 3, "spacing": 3 } ],
        "ground": [ { "block": "minecraft:fern", "chance": 0.15 }, { "block": "minecraft:short_grass", "chance": 0.15 }, { "block": "quark:lavender_blossom_sapling", "chance": 0.05 } ] } } ] },
    { "biomes": ["minecraft:plains", "minecraft:sunflower_plains", "minecraft:meadow"],
      "variants": [ { "weight": 1, "name": "yellow_blossom", "decoration": {
        "trees": [ { "feature": "minecraft:oak", "tries": 2, "spacing": 3 }, { "feature": "quark:yellow_blossom", "tries": 3, "spacing": 3 } ],
        "ground": [ { "block": "minecraft:short_grass", "chance": 0.30 }, { "block": "quark:yellow_blossom_sapling", "chance": 0.05 } ] } } ] },
    { "biomes": ["#minecraft:is_savanna"],
      "variants": [ { "weight": 1, "name": "orange_blossom", "decoration": {
        "trees": [ { "feature": "minecraft:acacia", "tries": 2, "spacing": 3 }, { "feature": "quark:orange_blossom", "tries": 3, "spacing": 3 } ],
        "ground": [ { "block": "minecraft:short_grass", "chance": 0.15 }, { "block": "quark:orange_blossom_sapling", "chance": 0.05 } ] } } ] },
    { "biomes": ["minecraft:desert", "#minecraft:is_badlands"],
      "variants": [ { "weight": 1, "name": "red_blossom", "decoration": {
        "trees": [ { "feature": "minecraft:oak", "tries": 2, "spacing": 3 }, { "feature": "quark:red_blossom", "tries": 3, "spacing": 3 } ],
        "ground": [ { "block": "minecraft:short_grass", "chance": 0.10 }, { "block": "quark:red_blossom_sapling", "chance": 0.04 } ] } } ] }
  ]
}
