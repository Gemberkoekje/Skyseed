{
  "_comment": "First-party Oh The Biomes We've Gone village compat (BWGVILLAGEPLAN): a Trade Post grown over a BWG village biome assembles that biome's BWG-styled village instead of the vanilla plains one. Each band swaps the jigsaw to a per-style pool set (skyseed:village_<style>, authored by BwgVillageTemplates in BWG's own block palette) and dresses the island surround with that biome's BWG trees + flora. Bands are PREPENDED by ThemeOverride.Patch.mergeBands so they win the first-match over the base overrides. Inert without BWG: the biomeswevegone: biome ids never match (band skipped) and the village .nbt (which carry biomeswevegone: block names) are only ever loaded when a village actually assembles over the biome. All 6 BWG village styles; style↔biome map from the jar's has_structure/village_* tags.",
  "target": "skyseed:trade_post",
  "biome_overrides": [
    { "_comment": "Skyris — an elegant elevated masonry town over the skyris vale.",
      "biomes": ["biomeswevegone:skyris_vale"],
      "surface": "minecraft:grass_block",
      "surface_scatter": [ { "block": "minecraft:podzol", "chance": 0.20 } ],
      "jigsaw": { "pool": "skyseed:village_skyris/start", "target": "minecraft:bottom", "depth": 4, "pad": 5, "reach": 48, "cap_prefix": "shop_", "cap_min": 2, "cap_count": 4, "cap_filler": "skyseed:village_skyris/fillers" },
      "variants": [
        { "weight": 1, "name": "skyris", "decoration": {
          "trees": [ { "feature": "biomeswevegone:skyris_trees", "tries": 3, "spacing": 3 } ],
          "ground": [
            { "block": "minecraft:short_grass", "chance": 0.25 },
            { "block": "minecraft:cornflower", "chance": 0.04 },
            { "block": "minecraft:lily_of_the_valley", "chance": 0.03 }
          ] } }
      ] },
